generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("VIEWER")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  resetTokens   PasswordResetToken[]
  performedLogs AuditLog[] @relation("PerformedBy")
  targetLogs    AuditLog[] @relation("TargetUser")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?

  @@index([email])
  @@index([token])
}

model Donor {
  id       String    @id @default(cuid())
  name     String
  email    String?
  phone    String?
  address  String?
  pan      String?
  receipts Receipt[]
}

model Vendor {
  id       String    @id @default(cuid())
  name     String
  email    String?
  phone    String?
  gstin    String?
}

model Account {
  id           String        @id @default(cuid())
  type         String
  category     String?
  accountType  String?
  balance      Float         @default(0)
  transactions Transaction[]
  budgets      Budget[]
}

model Receipt {
  id          String   @id @default(cuid())
  receiptNo   String   @unique
  date        DateTime
  donorId     String?
  type        String
  category    String?
  accountType String?
  eventName   String?
  amount      Float
  paymentMode String
  referenceNo String?
  accountId   String
  narration   String?
  attachment  String?
  createdAt   DateTime @default(now())
  donor       Donor?   @relation(fields: [donorId], references: [id])

  @@index([date])
  @@index([accountId])
  @@index([donorId])
  @@index([receiptNo])
}

model Payment {
  id          String   @id @default(cuid())
  voucherNo   String   @unique
  date        DateTime
  type        String
  category    String?
  accountType String?
  eventName   String?
  amount      Float
  paymentMode String
  chequeNo    String?
  bankName    String?
  accountId   String
  narration   String?
  attachment  String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())

  @@index([date])
  @@index([accountId])
  @@index([voucherNo])
}

model ContraEntry {
  id            String   @id @default(cuid())
  entryNo       String   @unique
  date          DateTime
  transferType  String
  fromAccountId String
  toAccountId   String
  amount        Float
  reference     String?
  narration     String?
  createdAt     DateTime @default(now())

  @@index([date])
  @@index([fromAccountId])
  @@index([toAccountId])
}

model Transaction {
  id        String   @id @default(cuid())
  accountId String
  debit     Float    @default(0)
  credit    Float    @default(0)
  refType   String
  refId     String
  date      DateTime
  createdAt DateTime @default(now())
  account   Account  @relation(fields: [accountId], references: [id])

  @@index([refId, refType])
  @@index([accountId, date])
  @@index([date])
  @@index([accountId])
}

model Budget {
  id          String   @id @default(cuid())
  accountId   String
  fiscalYear  Int
  totalAmount Float
  period      String   @default("ANNUAL") // MONTHLY, QUARTERLY, ANNUAL
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id])

  @@unique([accountId, fiscalYear])
}

model JournalVoucher {
  id          String   @id @default(cuid())
  voucherNo   String   @unique
  date        DateTime
  narration   String?
  attachment  String?
  createdAt   DateTime @default(now())

  @@index([date])
  @@index([voucherNo])
}

model AuditLog {
  id            String   @id @default(cuid())
  action        String
  performedById String
  targetUserId  String?
  targetEmail   String?
  details       String?
  createdAt     DateTime @default(now())

  performedBy User  @relation("PerformedBy", fields: [performedById], references: [id])
  targetUser  User? @relation("TargetUser", fields: [targetUserId], references: [id])

  @@index([action])
  @@index([performedById])
  @@index([createdAt])
}
// Enum for deletion request status
enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// Voucher types for targeted deletion (nullable for safe migration)
enum VoucherType {
  RECEIPT
  PAYMENT
  CONTRA
  JOURNAL
}

// Model for tracking voucher deletion requests
model DeletionRequest {
  id            String   @id @default(cuid())
  voucherId     String
  voucherType   VoucherType?
  requestedById String
  status        RequestStatus @default(PENDING)
  createdAt     DateTime @default(now())

  // Relations (optional, can be added later)
  // requestedBy   User @relation(fields: [requestedById], references: [id])

  @@index([voucherId])
}
